<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PRODE 2026 — <%- title || 'Mundial' %></title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚽</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
</head>
<body>

<!-- NAV -->
<nav class="navbar">
  <a class="nav-brand" href="/dashboard">
    <span class="brand-icon">⚽</span>
    <span class="brand-text">PRODE <strong>2026</strong></span>
  </a>

  <div class="nav-links">
    <a href="/dashboard"    class="nav-link <%= path === '/dashboard' ? 'active' : '' %>">Inicio</a>
    <a href="/partidos"     class="nav-link <%= path.startsWith('/partidos') || path.startsWith('/pronosticar') ? 'active' : '' %>">Partidos</a>
    <a href="/clasificacion"class="nav-link <%= path === '/clasificacion' ? 'active' : '' %>">Clasificación</a>
    <a href="/banter"       class="nav-link <%= path === '/banter' ? 'active' : '' %>">Banter Wall</a>
    <span class="nav-team-badge">Equipo 2</span>
    <% if (currentUser && currentUser.isAdmin) { %>
    <a href="/admin"        class="nav-link nav-admin <%= path === '/admin' ? 'active' : '' %>">Admin</a>
    <% } %>
  </div>

  <div class="nav-user">
    <% if (currentUser) { %>
    <div class="user-chip">
      <div class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
      <div class="user-info">
        <span class="user-name"><%= currentUser.name.split(' ')[0] %></span>
        <span class="user-pts"><%= currentUser.points %> pts</span>
      </div>
    </div>
    <a href="/logout" class="btn-logout" title="Cerrar sesión">⏻</a>
    <% } %>
  </div>

  <button class="nav-mobile-toggle" onclick="toggleNav()">☰</button>
</nav>

<!-- MOBILE NAV -->
<div class="mobile-nav" id="mobileNav">
  <a href="/dashboard"     onclick="toggleNav()">🏠 Inicio</a>
  <a href="/partidos"      onclick="toggleNav()">📅 Partidos</a>
  <a href="/clasificacion" onclick="toggleNav()">🏆 Clasificación</a>
  <a href="/banter"        onclick="toggleNav()">💬 Banter Wall</a>
  <% if (currentUser && currentUser.isAdmin) { %>
  <a href="/admin"         onclick="toggleNav()">⚙️ Admin</a>
  <% } %>
  <a href="/logout">⏻ Cerrar sesión</a>
</div>

<main class="main-content">
  <%- body %>
</main>

<footer class="footer">
  <p>⚽ PRODE Mundial 2026 &nbsp;·&nbsp; Equipo 2 &nbsp;·&nbsp; FIFA World Cup™</p>
</footer>

<script src="/js/app.js"></script>
<%- typeof extraScript !== 'undefined' ? extraScript : '' %>
</body>
</html>
