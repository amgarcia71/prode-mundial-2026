<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PRODE 2026 — Registro</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚽</text></svg>">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-bg"></div>
  <div class="auth-container" style="justify-content:center;">
    <div class="auth-card">
      <div class="auth-logo">
        <div class="auth-ball">⚽</div>
        <h1>PRODE <span>2026</span></h1>
        <p>Crea tu cuenta y empieza a pronosticar</p>
      </div>

      <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/registro" method="POST" class="auth-form">
        <div class="form-group">
          <label>Nombre completo</label>
          <input type="text" name="name" placeholder="Tu nombre" required>
        </div>
        <div class="form-group">
          <label>Correo corporativo</label>
          <input type="email" name="email" placeholder="tu@empresa.com" required>
        </div>
        <div class="form-group">
          <label>Contraseña</label>
          <input type="password" name="password" placeholder="Mínimo 6 caracteres" required minlength="6">
        </div>
        <div class="form-group">
          <label>Departamento</label>
          <select name="department">
            <option value="General">General</option>
            <option value="Ventas">Ventas</option>
            <option value="IT">IT</option>
            <option value="Marketing">Marketing</option>
            <option value="Finanzas">Finanzas</option>
            <option value="RH">Recursos Humanos</option>
            <option value="Operaciones">Operaciones</option>
            <option value="Dirección">Dirección</option>
          </select>
        </div>
        <button type="submit" class="btn-primary btn-full">Unirme al Prode ⚽</button>
      </form>

      <div class="auth-divider">¿Ya tienes cuenta?</div>
      <a href="/" class="btn-secondary btn-full">Iniciar sesión</a>
    </div>
  </div>
</body>
</html>
